#include <iostream>
#include <string>
using namespace std;

class Pessoa {
private:
    string nome;
    int idade;
    string endereco;
    string profissao;

public:
    // construtor
    Pessoa(string nome, int idade, string endereco, string profissao) {
        this->nome = nome;
        this->idade = idade;
        this->endereco = endereco;
        this->profissao = profissao;
    }

    // nome
    void setNome(string novoNome) {
        nome = novoNome;
    }

    string getNome() {
        return nome;
    }

    // idade
    void setIdade(int novaIdade) {
        idade = novaIdade;
    }

    int getIdade() {
        return idade;
    }

    // endereco
    void setEndereco(string novoEndereco) {
        endereco = novoEndereco;
    }

    string getEndereco() {
        return endereco;
    }

    // profissao
    void setProfissao(string novaProfissao) {
        profissao = novaProfissao;
    }

    string getProfissao() {
        return profissao;
    }

    // exibir info
    void mostrarInfo() {
        cout << "Nome: " << nome << endl;
        cout << "Idade: " << idade << endl;
        cout << "Endereco: " << endereco << endl;
        cout << "Profissao: " << profissao << endl;
    }
};